# Sao chép thành .env và chỉnh nếu cần (ví dụ dùng MongoDB Atlas).
MONGO_URI=mongodb://localhost:27017
MONGO_DB=cancer_project

# API
API_PREFIX=/api/v1
API_CORS_ORIGINS=http://localhost,http://127.0.0.1

# Spark / model
SPARK_MASTER=local[*]
MODEL_PATH=models/current/pipeline_model
MODEL_METADATA_PATH=models/current/metadata.json
